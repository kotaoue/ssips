#!/bin/bash
# ssips - sips wrapper for ImageMagick-style crop syntax
# Usage: ssips <WxH+X+Y> <input> [--out <output>]
#
# Crops <input> to a WxH region whose top-left corner is at (X, Y),
# equivalent to ImageMagick: convert input -crop WxH+X+Y output

set -euo pipefail

usage() {
    echo "Usage: ssips <WxH+X+Y> <input> [--out <output>]" >&2
    echo "  WxH+X+Y  crop geometry (width x height + left + top)" >&2
    exit 1
}

if [[ $# -lt 2 ]]; then
    usage
fi

crop_spec="$1"
input="$2"
shift 2

# Parse WxH+X+Y
if [[ "$crop_spec" =~ ^([0-9]+)x([0-9]+)\+([0-9]+)\+([0-9]+)$ ]]; then
    crop_w="${BASH_REMATCH[1]}"
    crop_h="${BASH_REMATCH[2]}"
    crop_x="${BASH_REMATCH[3]}"
    crop_y="${BASH_REMATCH[4]}"
else
    echo "Error: invalid crop geometry '$crop_spec'. Expected WxH+X+Y (e.g. 480x240+0+0)" >&2
    usage
fi

# Get image dimensions
if ! img_info=$(sips -g pixelWidth -g pixelHeight "$input" 2>&1); then
    echo "Error: could not read image properties from '$input'" >&2
    exit 1
fi
img_w=$(echo "$img_info" | awk '/pixelWidth/{print $2}')
img_h=$(echo "$img_info" | awk '/pixelHeight/{print $2}')
if [[ -z "$img_w" || -z "$img_h" ]]; then
    echo "Error: '$input' does not appear to be a valid image" >&2
    exit 1
fi


# Crop範囲が画像外にはみ出す場合でも、画像内の範囲だけクロップ（ImageMagick互換）
if (( crop_x < 0 )); then crop_w=$(( crop_w + crop_x )); crop_x=0; fi
if (( crop_y < 0 )); then crop_h=$(( crop_h + crop_y )); crop_y=0; fi
if (( crop_x + crop_w > img_w )); then crop_w=$(( img_w - crop_x )); fi
if (( crop_y + crop_h > img_h )); then crop_h=$(( img_h - crop_y )); fi
# 無効な範囲はエラー
if (( crop_w <= 0 || crop_h <= 0 )); then
    echo "Error: crop region is outside image bounds or too small" >&2
    exit 1
fi

# Calculate cropOffset values.
# sips --cropOffset specifies the top-left corner of the crop region.
# Format: --cropOffset offsetY offsetX (pixels from top, pixels from left)
# Note: sips treats (0,0) as "no offset" (center crop), so we use 1 instead of 0.
offset_w="$crop_x"
offset_h="$crop_y"
if (( offset_w == 0 && offset_h == 0 )); then
    # Both are 0: use (1, 1) to crop from top-left
    offset_w=1
    offset_h=1
fi

echo "sips -c $crop_h $crop_w --cropOffset $offset_h $offset_w $input $@" >&2
exec sips -c "$crop_h" "$crop_w" --cropOffset "$offset_h" "$offset_w" "$input" "$@"
